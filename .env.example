# Copy to .env for local development. On Vercel, set these in Project Settings > Environment Variables.

# Base URL of the app (used for OAuth redirects). Local dev = Vite dev server.
APP_URL=http://localhost:5173

# GitHub OAuth App credentials — create at https://github.com/settings/developers
# Authorization callback URL must be:  {APP_URL}/api/auth/github/callback
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# Secret used to sign the session cookie. Use a long random string.
JWT_SECRET=change-me-to-a-long-random-string

# MongoDB Atlas connection string (free tier). Get one at https://cloud.mongodb.com
MONGODB_URI=

# Only set locally; Vercel sets NODE_ENV=production automatically.
# NODE_ENV=development
